# Copy to .env.signing (gitignored) and fill in.
#
# Local signing + notarization for macOS releases and TestFlight uploads.
# Never commit .env.signing — it holds identifiers, not secrets, but habit.

# === macOS: sign + notarize (scripts/sign-macos.sh) ===

# Full codesign identity string — run `security find-identity -v -p codesigning` to see it.
# Looks like: "Developer ID Application: Your Name (TEAMID1234)"
SIGNING_IDENTITY="Developer ID Application: YOUR NAME (TEAMID1234)"

# Keychain profile name for notarytool. One-time setup:
#   xcrun notarytool store-credentials "teale-notary" \
#     --key ~/path/to/AuthKey_XXXXXX.p8 --key-id XXXXXX --issuer YYYYYYYY-...
NOTARY_PROFILE="teale-notary"

# === iOS: TestFlight upload (scripts/upload-testflight.sh) ===

# 10-char Apple Developer team ID (shown in developer portal membership page).
TEAM_ID="TEAMID1234"

# App Store Connect API key (Users and Access → Integrations → App Store Connect API).
API_KEY_ID="ABC123DEF4"
API_ISSUER_ID="69a6de70-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Absolute path to the downloaded .p8 key file. altool also searches these dirs in order:
#   ./private_keys/
#   ~/private_keys/
#   ~/.private_keys/
#   ~/.appstoreconnect/private_keys/
# Place the .p8 in one of those for altool to find it automatically.
API_KEY_PATH="${HOME}/.appstoreconnect/private_keys/AuthKey_ABC123DEF4.p8"
