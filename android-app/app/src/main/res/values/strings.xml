    <!-- Tasks -->
    <string name="tasks_title">Tasks</string>
    <string name="tasks_subtitle">Scheduled assistant jobs that run through Teale over the network. Reliable tonight means WorkManager jobs, explicit capability gates, and honest Android limits.</string>
